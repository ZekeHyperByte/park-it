# =============================================================================
# Application
# =============================================================================
APP_NAME=E-Parking v2
APP_ENV=development
DEBUG=true

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=parking
DB_USER=parking
DB_PASSWORD=parking_secret
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# pgBouncer (use this for app connections in production)
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=6432
PGBOUNCER_POOL_MODE=transaction

# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =============================================================================
# Authentication (JWT)
# =============================================================================
JWT_SECRET=change-me-in-production-use-a-64-char-random-string-here-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Security
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Hardware / Business Defaults
# =============================================================================
DEFAULT_EMONEY_MINIMUM_BALANCE=10000
DEFAULT_PAYMENT_TIMEOUT_SECONDS=120
DEFAULT_PRINT_DECISION_TIMEOUT_SECONDS=10
DEFAULT_GATE_CLOSE_DURATION_MS=5000

# =============================================================================
# Settlement
# =============================================================================
SETTLEMENT_SCHEDULE=0 2 * * *
SETTLEMENT_AUTO_UPLOAD=false

# =============================================================================
# Notifications
# =============================================================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
