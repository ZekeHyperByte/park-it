# =============================================================================
# Application
# =============================================================================
APP_NAME=E-Parking v2
APP_ENV=development
DEBUG=true

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=parking
DB_USER=parking
DB_PASSWORD=parking_secret
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =============================================================================
# Authentication (JWT)
# =============================================================================
JWT_SECRET=change-me-in-production-use-a-64-char-random-string-here-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Security
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Notifications
# =============================================================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# Internal API key for booth bridge / machine-to-machine auth
# =============================================================================
INTERNAL_API_KEY=change-me-in-production
